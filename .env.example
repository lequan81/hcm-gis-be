# ── HCMC 3D Building Tiles — Backend Configuration ──

# Server
PORT=3001

# CORS — allowed origins (comma-separated for multiple frontends)
CORS_ORIGIN=http://localhost:5173
# Tile source API
TILE_API_URL=https://bando.tphcm.gov.vn/service/gisp/tile/building
TILE_REFERER=https://bando.tphcm.gov.vn/
TILE_ORIGIN=https://bando.tphcm.gov.vn

# Output & logs directories (relative to backend/src/ or absolute)
OUTPUT_DIR=../output
LOG_DIR=../logs

# Download settings
ZOOM=16
TILE_OVERLAP=1
CONCURRENCY=12
RETRY_DELAY_MS=2000

# Performance tuning
TILE_SLEEP_MS=20
TILE_BATCH_SIZE=1000

# Default vector layer name
LAYER_NAME=region_building3d_index

# Worker pool — max concurrent worker threads (default 4, safe for 2GB RAM)
# Each worker uses ~50MB RAM. 4 workers = ~200MB overhead.
WORKER_POOL_SIZE=4

# Global tile fetch concurrency — max simultaneous HTTP requests to bando.tphcm.gov.vn
GLOBAL_TILE_CONCURRENCY=75
